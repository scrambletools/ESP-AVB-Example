# Wireless endpoint overrides — selected when building with
# IDF_TARGET=esp32c6 (e.g. for ESP3, the C6 + onboard ES8311 test board).
# Chained on top of sdkconfig.defaults; only the target-specific
# divergences belong here.

# Per-port topology — esp_ptp is the single source of truth; the
# matching ESP_AVB_* mirrors are derived in esp_avb/Kconfig.projbuild.
#   port 0: wifi (native on-chip radio, host_if=ahb), primary endpoint,
#           STA mode, ~150 Mbps negotiated cap.
# Phase 6a brought up Wi-Fi + beacon-IE consumer + FTM initiator;
# Phase 6b runs the full AVB stack on this port.
CONFIG_ESP_PTP_NUM_PORTS=1
CONFIG_ESP_PTP_PORT0_MEDIUM_WIFI_FTM=y
CONFIG_ESP_PTP_PORT0_HOST_IF_AHB=y
CONFIG_ESP_PTP_PORT0_TYPE_PRIMARY=y
CONFIG_ESP_PTP_PORT0_WIFI_MODE_STA=y
CONFIG_ESP_PTP_PORT0_LINK_SPEED_MBPS=150

# Disable listener fast-connect on this build — it interferes with the
# Phase 3 class-selection demo by re-binding with default (Class A) flags
# within milliseconds of any controller-driven disconnect. Test-only.
CONFIG_ESP_AVB_DISABLE_FAST_CONNECT=y

# FTM: initiator on STA per IEEE 802.1AS-2020 §12.1.2 (slave initiates).
# Responder also enabled so this board can serve as the AP-side test
# peer during development. ESP_WIFI_FTM_ENABLE must be y for the
# *_SUPPORT children to take effect.
CONFIG_ESP_WIFI_FTM_ENABLE=y
CONFIG_ESP_WIFI_FTM_INITIATOR_SUPPORT=y
CONFIG_ESP_WIFI_FTM_RESPONDER_SUPPORT=y
CONFIG_ESP_WIFI_SOFTAP_SUPPORT=n
CONFIG_PARTITION_TABLE_SINGLE_APP_LARGE=y

# Wider RX BA window so the wireless listener can accept large A-MPDU
# aggregates from the bridge AP (C6 supports HE; range is 2..64). The
# default of 6 caps the negotiated BA window even when the AP offers
# more, since 802.11 uses min(tx_ba_win, rx_ba_win) per direction.
CONFIG_ESP_WIFI_RX_BA_WIN=64
# Required by IDF's WIFI_RX_BA_WIN size check: WIN <= DYNAMIC_RX_BUFFER_NUM
# AND WIN <= 2 * STATIC_RX_BUFFER_NUM.
CONFIG_ESP_WIFI_STATIC_RX_BUFFER_NUM=32
CONFIG_ESP_WIFI_DYNAMIC_RX_BUFFER_NUM=64

# Heap-trace is off by default. The scaffold in avb_endpoint.c
# (#ifdef CONFIG_HEAP_TRACING_STANDALONE) and the heap-watcher log in
# esp_avb/avbstats.c stay in the source so future leak investigations
# are a single Kconfig toggle away. To re-enable, set:
#   CONFIG_HEAP_TRACING_STANDALONE=y
#   CONFIG_HEAP_TRACING_STACK_DEPTH=6
#   CONFIG_ESP_SYSTEM_USE_FRAME_POINTER=y
# in the active sdkconfig (not just defaults).
CONFIG_HEAP_TRACING_OFF=y
# CONFIG_HEAP_TRACING_STANDALONE is not set
