menu "AVB Example Configuration"
    
    config EXAMPLE_AVB_ENTITY_NAME
        string "Entity Name"
        default "AVB Example Entity"
        help
            Set the name of the AVB entity. This name will be used 
            to identify this device in the AVB network.

    config EXAMPLE_AVB_MODEL_ID
        hex "Model ID"
        default 0x0000007468696e67
        help
            Set the model ID for this AVB entity. This ID should uniquely identify 
            the model/type of AVB device within your vendor's product line.

    config EXAMPLE_AVB_TALKER
        bool "Enable AVB Talker"
        default y
        help
            Function as AVB Talker.

    config EXAMPLE_AVB_TALKER_AUTO_STREAM
        bool "Auto Stream"
        depends on EXAMPLE_AVB_TALKER
        default n
        help
            Automatically start streaming when link is up. (not implemented yet)
      
    choice EXAMPLE_SELECT_MIC_GAIN
        prompt "Default MIC gain"
        depends on EXAMPLE_AVB_TALKER
        default MIC_GAIN_6DB
        help
            Select a codec-independent default mic gain. The AVB component
            clamps and rounds this to the nearest value supported by the
            selected codec.

        config MIC_GAIN_0DB
            bool "0 dB"
        config MIC_GAIN_6DB
            bool "6 dB"
        config MIC_GAIN_12DB
            bool "12 dB"
        config MIC_GAIN_18DB
            bool "18 dB"
        config MIC_GAIN_24DB
            bool "24 dB"
    endchoice
      
    config EXAMPLE_AVB_MIC_GAIN_TENTH_DB
        depends on EXAMPLE_AVB_TALKER
        int
        default 0 if MIC_GAIN_0DB
        default 60 if MIC_GAIN_6DB
        default 120 if MIC_GAIN_12DB
        default 180 if MIC_GAIN_18DB
        default 240 if MIC_GAIN_24DB

    config EXAMPLE_AVB_LISTENER
        bool "Enable AVB Listener"
        default y
        help
            Function as AVB Listener.

    config EXAMPLE_AVB_LISTENER_AUTO_CONNECT
        bool "Auto Connect"
        depends on EXAMPLE_AVB_LISTENER
        default n
        help
            Automatically connect to an AVB Talker with the same entity model ID. (not implemented yet)
      
    config EXAMPLE_AVB_SPEAKER_VOL_TENTH_DB
        int "Default speaker volume (tenths of dB)"
        depends on EXAMPLE_AVB_LISTENER
        range -955 0
        default -100
        help
            Set a codec-independent default speaker digital volume in tenths
            of dB. For example, -100 is -10.0 dB and 0 is 0.0 dB. The AVB
            component clamps and rounds this to the nearest value supported
            by the selected codec.

    config EXAMPLE_AVB_REMOTE_CONTROL
        bool "Allow remote control via ATDECC"
        default y
        help
            Allow an AVB Controller to control this device via ATDECC protocol. If not set it will break Milan compliance.

    config EXAMPLE_AVB_CODEC_DISABLED
        bool "Skip codec + I2S init (control plane only)"
        default n
        help
            Set avb_config.codec_disabled=true so I2S and codec init
            are skipped. Use on boards where the wired codec does not
            match the default (e.g. an ES8388 hat on a P4-ETH host
            where the default selection is ES8311). The control plane
            — ATDECC, MSRP, MVRP, MAAP — runs unaffected; only audio
            I/O is disabled. Used for control-plane reproduction
            tests on hosts without matching audio hardware.

    config EXAMPLE_AVB_CODEC_ES8388_HAT
        bool "Use ES8388 Scramble Hat (overrides ES8311 onboard default)"
        default n
        depends on !EXAMPLE_AVB_CODEC_DISABLED
        help
            Use the Scramble Hat ES8388 codec instead of the onboard
            ES8311. Overrides avb_config.codec_type to
            avb_codec_type_es8388 and remaps codec_pins to the Scramble
            Hat layout (per the comment block in esp_avb/avbconfig.h:
            MCLK=16 BCLK=17 WS=19 DOUT=18 DIN=54 I2C_SDA=21 I2C_SCL=20
            PA=-1). Boards: ESP32-P4-ETH fitted with the Scramble Hat
            (e.g. ESP1).

    config AVB_ENDPOINT_PERF_TEST_MODE
        bool "Perf-test mode (skip PTP/AVB/codec, count matching AVTP frames on WiFi STA)"
        default n
        depends on ESP_PTP_PORT0_MEDIUM_WIFI_FTM || ESP_PTP_PORT1_MEDIUM_WIFI_FTM
        help
            Replaces the production bring-up. Only NVS + esp_event + WiFi
            STA come up; ptpd, AVB and the codec are NOT started. An
            esp_wifi_internal_reg_rxcb hook counts AVTP frames whose
            dest MAC + stream ID match the configured pair. A 1 Hz
            stats task logs pps and Mbps. Pair with
            CONFIG_AVB_BRIDGE_PERF_TEST_MODE on the bridge to measure
            end-to-end throughput across SDIO + 802.11.

            Visible only on builds where a WiFi STA medium is configured
            (the C6 wireless endpoint build).

    config AVB_ENDPOINT_PERF_TEST_DEST_MAC
        string "Test destination MAC (six colon-separated hex octets)"
        default "91:e0:f0:00:fe:00"
        depends on AVB_ENDPOINT_PERF_TEST_MODE
        help
            Must match the bridge perf-test mode's DEST_MAC. Frames with
            any other dest MAC are dropped at the filter and counted
            separately so a mis-pair is visible in the heartbeat.

    config AVB_ENDPOINT_PERF_TEST_STREAM_ID
        string "Test AVTP stream ID (eight colon-separated hex octets)"
        default "80:f1:b2:d2:ca:e0:00:01"
        depends on AVB_ENDPOINT_PERF_TEST_MODE
        help
            Must match the bridge perf-test mode's STREAM_ID. Frames
            with any other stream_id are dropped at the filter.

    config AVB_ENDPOINT_PERF_TEST_DURATION_SEC
        int "Test duration seconds (0 = run forever)"
        default 10
        range 0 86400
        depends on AVB_ENDPOINT_PERF_TEST_MODE
        help
            Counted from the first matching RX. After expiry the stats
            task prints a one-line summary and stops sampling; the WiFi
            stack stays up so re-running the bridge side just needs a
            board reset on the bridge.

endmenu
